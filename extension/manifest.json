{
  "manifest_version": 3,
  "name": "Agency Viz — Save to Swipe File",
  "version": "0.1.0",
  "description": "Save Meta Ad Library ads directly into your Agency Viz Swipe File.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://www.facebook.com/ads/library/*",
    "https://*.fbcdn.net/*",
    "https://app.agencyviz.com/*",
    "http://localhost/*",
    "http://localhost:3000/*",
    "http://localhost:3001/*",
    "http://localhost:3002/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.facebook.com/ads/library/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Agency Viz"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
