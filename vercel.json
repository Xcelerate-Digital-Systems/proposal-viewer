{
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/view/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/flush-review-notifications",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/ghl-sync",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/meta-api-health",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/review-reminders",
      "schedule": "0 8 * * *"
    }
  ]
}
